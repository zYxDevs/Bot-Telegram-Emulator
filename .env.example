# Salin file ini jadi `.env` lalu isi nilai aslinya. JANGAN commit .env asli.
TELEGRAM_TOKEN=isi_token_dari_botfather
FREEMODEL_KEY=isi_key_dari_freemodel.dev
TOKENROUTER_KEY=isi_key_dari_tokenrouter.com

# === OPSIONAL — boleh dikosongin, fallback otomatis ke DuckDuckGo ===
SERPER_API_KEY=
TAVILY_API_KEY=
FIRECRAWL_API_KEY=

# Admin Telegram user_id (pisah koma). Admin bebas rate-limit.
ADMIN_IDS=

# === TELEGRAM TRANSPORT ===
# Default polling. Untuk VPS + domain HTTPS:
# TELEGRAM_MODE=webhook
# TELEGRAM_WEBHOOK_URL=https://bot.domainlu.com
# TELEGRAM_WEBHOOK_SECRET=random_path_secret
# TELEGRAM_WEBHOOK_PATH=/telegram-webhook/random_path_secret

# === OPS PANEL / ADMIN HTTP ===
# Bind lokal by default; expose lewat nginx/Cloudflare tunnel kalau perlu.
# ADMIN_WEB_HOST=127.0.0.1
# ADMIN_WEB_PORT=8787
# ADMIN_WEB_TOKEN=isi_token_panel

# === LLM ROUTING ===
# Default direct ke freemodel. Di VPS bisa diarahkan ke 9router lokal.
# COPUX_API_URL=http://127.0.0.1:20128/v1/chat/completions
# COPUX_API_KEY=sk_xxx
# TEXT_MODEL=copux-stack
# VISION_MODEL=copux-stack

# Fallback tambahan kalau primary error/down. Pisah koma, urutan sejajar.
# LLM_FALLBACK_URLS=https://api.freemodel.dev/v1/chat/completions
# LLM_FALLBACK_MODELS=gpt-5.5
# LLM_FALLBACK_KEYS=isi_key_dari_freemodel.dev
# LLM_ROUTE=             # optional override runtime default route/model

# === INFRA / RESILIENCE ===
# AUTO_BACKUP_ENABLED=1
# BACKUP_DIR=/root/Bot-Telegram/data/backups
# BACKUP_KEEP=14
# BACKUP_INTERVAL_MS=86400000
# NINEROUTER_DB=/root/.9router/db/data.sqlite
# BACKUP_ENCRYPTION_PASSWORD=      # optional: kalau diisi, backup jadi .tar.gz.enc
# BACKUP_KEEP_PLAIN=0              # set 1 kalau mau simpan plain + encrypted
# SELF_HEAL_ENABLED=1
# SELF_HEAL_INTERVAL_MS=60000
# SELF_HEAL_FAIL_THRESHOLD=3
# MAX_CONCURRENT_WEB_FETCH=2
# MAX_CONCURRENT_SEARCH=2

# === ADAPTIVE TUNING — turunin di HP low-RAM Termux, naikin di server lega ===
# VISION_MODEL=gpt-5.5       # model freemodel pas user kirim gambar (default gpt-5.5)
# TEXT_MODEL=MiniMax-M3      # model tokenrouter pas text-only (default MiniMax-M3)
# MAX_HISTORY=10             # turn obrolan diingat (per-user). HP <4GB pake 6-8.
# MAX_FILE_SIZE_BYTES=1048576    # batas baca dokumen (default 1MB)
# MAX_PHOTO_BYTES=6291456    # batas download foto (default 6MB). HP low-RAM pake 3MB.
# MAX_FETCH_BYTES=4194304    # batas web_fetch (default 4MB)
# FIRECRAWL_TIMEOUT_MS=45000  # timeout fallback Firecrawl web_fetch
# FIRECRAWL_MAX_AGE_MS=3600000 # cache age Firecrawl 1 jam
# MAX_CONCURRENT_LLM=3       # global cap LLM paralel. HP 2-4GB pake 1-2, server lega 5+.
# SESSION_TTL_MS=21600000    # TTL sesi 6 jam
# SAVE_DEBOUNCE_MS=5000      # debounce flush history
